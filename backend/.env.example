APP_NAME=Asset Tracking System
APP_VERSION=1.0.0
DEBUG=False

SECRET_KEY=replace_with_a_long_random_secret

# Option 1: use a single hosted database URL
DATABASE_URL=mysql+pymysql://user:password@host:3306/asset_tracking_db

# Option 2: use individual DB fields instead of DATABASE_URL
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=asset_tracking_db

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
